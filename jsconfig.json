{
  "compilerOptions": {
    "moduleResolution": "node",
    "target": "es2022",
    "module": "esnext",
    "allowJs": true,
    "checkJs": true,
    "noEmit": true,
    "noImplicitAny": false,
    "strictNullChecks": false,
    "ignoreDeprecations": "6.0",
    "types": ["node"],
    "skipLibCheck": true
  },
  "include": ["scripts/**/*"],
  "exclude": ["node_modules"]
}
