# portfolio-site environment — copy to .env and fill in. Never commit .env.
# SMTP2GO sending credentials (dedicated "portfolio.gregiteen.xyz" SMTP user)
SMTP_HOST=mail.smtp2go.com
SMTP_PORT=2525
SMTP_SECURE=false
SMTP_USER=portfolio.gregiteen.xyz
SMTP_PASS=

# Sender identity (verified sender domain in SMTP2GO)
MAIL_FROM='"Greg Iteen" <sales@gregiteen.xyz>'

# Where new-visitor notifications are sent
MAIL_OWNER=gregiteen@gmail.com

# Server port (optional, default 4173)
# PORT=4173

# Documenso (open-source DocuSign alternative, documenso.com) — optional. If
# unset, proposals still send as a branded letterhead PDF attachment, just
# without an e-signature link. Self-host via the official production
# docker-compose (see docs.documenso.com/developers/self-hosting); the
# self-hosted API additionally requires S3-compatible storage (local
# filesystem storage only supports the web UI upload flow, not the API) —
# NEXT_PUBLIC_UPLOAD_TRANSPORT=s3 plus a MinIO/S3 endpoint on the Documenso
# side. Generate an API key from Documenso's Settings > API Tokens page.
# (DocuSeal was evaluated first and rejected: its self-hosted API is
# paywalled behind a $20/mo Pro license even though the project is AGPL —
# verified live, `/submissions/pdf` returns 404 "available in Pro Edition".
# Documenso's API is genuinely free self-hosted — confirmed via a real
# end-to-end submission.)
# DOCUMENSO_BASE_URL=https://sign.gregiteen.xyz
# DOCUMENSO_API_KEY=
# Required when configuring the production Documenso webhook at
# https://gregiteen.xyz/api/documenso-webhook. Use one high-entropy value in
# both places; incoming events without this exact header are rejected.
# DOCUMENSO_WEBHOOK_SECRET=
# One-time SSO from the authenticated custom webmail CRM into the Signed, gi.
# workspace. Store this only in Total Recall and project it into both runtimes.
# DOCUMENSO_SSO_SECRET=
# DOCUMENSO_SSO_EMAIL=sales@gregiteen.xyz

# Custom webmail (mail.gregiteen.xyz) — talks directly to Dovecot/Postfix.
# Defaults to 127.0.0.1 (loopback), correct for production since serve.mjs
# runs on the same droplet as the mail server. Only override for local dev,
# pointing at the droplet's public IP so you can test against real mail
# without deploying first.
# WEBMAIL_IMAP_HOST=127.0.0.1
# WEBMAIL_IMAP_PORT=993
# WEBMAIL_SMTP_HOST=127.0.0.1
# WEBMAIL_SMTP_PORT=587
