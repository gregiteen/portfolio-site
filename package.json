{
  "name": "portfolio-site",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "An SSSS-native project — Markdown vault as source of truth.",
  "scripts": {
    "ssss": "ssss",
    "sync-registry": "node scripts/sync-registry.mjs",
    "postinstall": "node scripts/sync-registry.mjs",
    "build": "node scripts/build-site.mjs",
    "rate-card:pdf": "node scripts/generate-rate-card-pdf.mjs",
    "dev": "node scripts/build-site.mjs && node scripts/serve.mjs",
    "test": "node --test --test-concurrency=1 test/*.test.mjs",
    "export": "ssss export vault --profile sale --registry vault-registry --out dist/bundle.ucw.json",
    "validate": "ssss conformance --engine"
  },
  "dependencies": {
    "@ssss/cli": "github:gregiteen/ssss#v0.7.0",
    "imapflow": "^1.4.6",
    "mailparser": "^3.9.14",
    "nodemailer": "^9.0.3",
    "pdfkit": "^0.19.1",
    "playwright": "^1.61.1",
    "sharp": "^0.35.3",
    "stripe": "^22.3.1"
  },
  "devDependencies": {
    "@types/node": "^26.1.0",
    "better-sqlite3": "^12.11.1",
    "total-recall-brain": "^3.18.2"
  },
  "overrides": {
    "total-recall-brain": {
      "@ssss/cli": "github:gregiteen/ssss#31e1245af1f02abe17d5655b0ee33ed464d25b70"
    }
  }
}
